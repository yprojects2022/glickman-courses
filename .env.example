# =============================================
# Glickman Courses — Environment Variables
# Copy to .env.local for development
# =============================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/glickman_courses

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ישורון גליקמן | קורסים

# =============================================
# Payment Providers (enable/disable via IS_ACTIVE)
# =============================================

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_IS_ACTIVE=true

# --- Tranzila ---
TRANZILA_TERMINAL=your_terminal_name
TRANZILA_PASSWORD=your_password
TRANZILA_IS_ACTIVE=false

# --- Grow ---
GROW_API_KEY=your_grow_api_key
GROW_SECRET=your_grow_secret
GROW_IS_ACTIVE=false

# =============================================
# Email (Nodemailer)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=ישורון גליקמן <noreply@glickman.co.il>

# =============================================
# Storage (for video uploads)
# =============================================
# Option A: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-west-1

# Option B: Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Admin
ADMIN_EMAIL=admin@glickman.co.il
